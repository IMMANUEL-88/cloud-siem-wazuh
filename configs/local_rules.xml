<group name="cowrie,honeypot,ssh,">

  <rule id="100001" level="3">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.</field>
    <description>Cowrie Honeypot Event Detected: $(eventid)</description>
  </rule>

  <rule id="100002" level="10">
    <if_sid>100001</if_sid>
    <field name="eventid">^cowrie\.login\.success</field>
    <description>Cowrie: Successful SSH login by $(username) from $(src_ip)</description>
  </rule>

  <rule id="100003" level="6">
    <if_sid>100001</if_sid>
    <field name="eventid">^cowrie\.login\.failed</field>
    <description>Cowrie: Failed SSH login attempt by $(username) from $(src_ip)</description>
  </rule>

  <rule id="100004" level="8">
    <if_sid>100001</if_sid>
    <field name="eventid">^cowrie\.command\.input</field>
    <description>Cowrie: Attacker executed command '$(input)' from $(src_ip)</description>
  </rule>

</group>
